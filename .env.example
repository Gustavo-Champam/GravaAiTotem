# Copie este arquivo para .env.local e preencha com a sua chave do Google Gemini.
#   cp .env.example .env.local
# Gere a chave em https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=sua-chave-aqui
# gemini-2.5-flash funciona no nível gratuito; gemini-2.0-flash pode estar com cota 0.
VITE_GEMINI_MODEL=gemini-2.5-flash
